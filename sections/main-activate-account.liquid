<div class="grid no-gutter">
  <div class="col xs12 m4 offset-m4">
    {% form 'activate_customer_password', class: 'flex flex-col flex-gap-medium' %}
      <h1 class="text-h4">{{ 'customer.activate.title' | t }}</h1>
      <p class="text-meta">{{ 'customer.activate.subtitle' | t }}</p>

      {{ form.errors | default_errors }}

      <div class="form-group">
        <div class="form-field">
          <label for="{{ section.id | append: '-password' }}">
            {{- 'form.password' | t -}}
          </label>

          <input
            id="{{ section.id | append: '-password' }}"
            name="customer[password]"
            type="password"
          >
        </div>

        <div class="form-field">
          <label for="{{ section.id | append: '-password-confirmation' }}">
            {{ 'form.confirm_password' | t }}
          </label>

          <input
            id="{{ section.id | append: '-password-confirmation' }}"
            name="customer[password_confirmation]"
            type="password"
          >
        </div>

        <button class="button">{{ 'form.submit' | t }}</button>

        <button class="text-link button-reset" name="decline">
          {{ 'customer.activate.decline' | t }}
        </button>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "class": "container section-margin"
}
{% endschema %}
